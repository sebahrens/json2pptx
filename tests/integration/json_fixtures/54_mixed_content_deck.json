{
  "template": "modern-template",
  "output_filename": "54_mixed_content_deck.pptx",
  "footer": {
    "enabled": true,
    "left_text": "Integration Test Suite"
  },
  "slides": [
    {
      "slide_type": "title",
      "content": [
        {"placeholder_id": "title", "type": "text", "text_value": "Full Feature Showcase"},
        {"placeholder_id": "subtitle", "type": "text", "text_value": "Testing Every Content Type Together"}
      ],
      "transition": "fade",
      "transition_speed": "fast"
    },
    {
      "slide_type": "content",
      "content": [
        {"placeholder_id": "title", "type": "text", "text_value": "Overview"},
        {
          "placeholder_id": "body",
          "type": "body_and_bullets",
          "body_and_bullets_value": {
            "body": "This deck tests all features together in one presentation.",
            "bullets": ["Charts and diagrams", "Tables and formatting", "Transitions and builds"],
            "trailing_body": "Each slide type is represented."
          }
        }
      ],
      "speaker_notes": "Intro slide"
    },
    {
      "slide_type": "chart",
      "content": [
        {"placeholder_id": "title", "type": "text", "text_value": "Revenue Chart"},
        {
          "placeholder_id": "body",
          "type": "chart",
          "chart_value": {
            "type": "bar_chart",
            "title": "Quarterly Revenue",
            "data": [
              {"label": "Q1", "value": 100},
              {"label": "Q2", "value": 150},
              {"label": "Q3", "value": 130},
              {"label": "Q4", "value": 180}
            ]
          }
        }
      ]
    },
    {
      "slide_type": "two-column",
      "content": [
        {"placeholder_id": "title", "type": "text", "text_value": "Side by Side"},
        {"placeholder_id": "body", "type": "bullets", "bullets_value": ["Left point 1", "Left point 2"]},
        {"placeholder_id": "body_2", "type": "bullets", "bullets_value": ["Right point 1", "Right point 2"]}
      ]
    },
    {
      "slide_type": "content",
      "content": [
        {"placeholder_id": "title", "type": "text", "text_value": "Data Table"},
        {
          "placeholder_id": "body",
          "type": "table",
          "table_value": {
            "headers": ["Metric", "Value"],
            "rows": [
              ["Revenue", "$180M"],
              ["Growth", "+25%"],
              ["NPS", "72"]
            ]
          }
        }
      ]
    },
    {
      "slide_type": "diagram",
      "content": [
        {"placeholder_id": "title", "type": "text", "text_value": "Strategic View"},
        {
          "placeholder_id": "body",
          "type": "diagram",
          "diagram_value": {
            "type": "swot",
            "title": "SWOT",
            "data": {
              "strengths": ["Brand", "Team"],
              "weaknesses": ["Cost"],
              "opportunities": ["AI", "Growth"],
              "threats": ["Competition"]
            }
          }
        }
      ],
      "build": "bullets"
    },
    {
      "slide_type": "section",
      "content": [
        {"placeholder_id": "title", "type": "text", "text_value": "Thank You"}
      ],
      "source": "Generated by integration test suite"
    }
  ]
}
