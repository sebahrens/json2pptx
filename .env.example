# ============================================================================
# Go Slide Creator - Environment Variables
# ============================================================================
# Copy this file to .env and configure for your environment.
# API keys and secrets should NEVER be committed to version control.
# ============================================================================

# ----------------------------------------------------------------------------
# Application Configuration
# ----------------------------------------------------------------------------

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# Server port (default: 8080)
PORT=8080

# Template directory path
TEMPLATES_DIR=./templates

# Output directory for generated files
OUTPUT_DIR=./output

# Template validation mode: strict or soft (default: soft)
# strict: fail on validation errors, soft: warn and continue
TEMPLATE_VALIDATION_MODE=soft

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------

# Authentication mode: disabled, token, api_key
SERVER_AUTH_MODE=disabled

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# ----------------------------------------------------------------------------
# LLM Provider Configuration
# ----------------------------------------------------------------------------

# LLM provider: openrouter, anthropic, openai
LLM_PROVIDER=openrouter

# API keys (set at least one for LLM features)
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# LLM request timeout
LLM_TIMEOUT=60s

# Maximum retries for failed LLM requests
LLM_MAX_RETRIES=3

# Health check cache TTL
LLM_HEALTH_CACHE_TTL=30s

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------

# Max concurrent conversion requests
CONVERT_RATE_LIMIT=10

# Conversion timeout (seconds)
CONVERT_TIMEOUT=180

# ----------------------------------------------------------------------------
# Storage Configuration
# ----------------------------------------------------------------------------

# Maximum age for temp files before cleanup (seconds)
TEMP_FILE_MAX_AGE=3600

# Temp file cleanup interval (seconds)
TEMP_CLEANUP_INTERVAL=300

# ----------------------------------------------------------------------------
# Image Security
# ----------------------------------------------------------------------------

# Allowed base paths for image loading (comma-separated)
# Leave empty to allow any path (validates for traversal but no sandbox)
ALLOWED_IMAGE_PATHS=

# ----------------------------------------------------------------------------
# SVG Conversion
# ----------------------------------------------------------------------------

# SVG conversion strategy: png, emf, native
SVG_STRATEGY=png

# SVG to PNG scale factor (default: 2.0)
SVG_SCALE=2.0

# Native SVG compatibility mode: warn, fallback, strict, ignore
SVG_NATIVE_COMPATIBILITY=warn

# PNG converter preference: auto, rsvg-convert, resvg
SVG_PNG_CONVERTER=auto

# ----------------------------------------------------------------------------
# Debug/Development (DO NOT USE IN PRODUCTION)
# ----------------------------------------------------------------------------

# Enable pprof profiling server (0 = disabled)
PPROF_PORT=0

# pprof bind address (localhost only for security)
PPROF_BIND=127.0.0.1
