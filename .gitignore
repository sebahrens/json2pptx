!/templates/embed.go
!/templates/midnight-blue.pptx
!/templates/forest-green.pptx
!/templates/warm-coral.pptx
!/templates/modern-template.pptx

# Environment
.env
.env.local
session-*.md
CLAUDE-SKILL-*.md

# Stray font files at repo root (fonts belong in fonts/)
/*.ttf
/*.otf

# Generated PDFs
*.pdf

# Private/proprietary templates (not for distribution)
/private/

# Security audit reports (internal use only)
specs/*security-audit*

# Archives and distribution bundles
*.zip
*.tar.gz
dist/

# Extracted PPTX internals (don't commit raw OOXML)
/ppt/
/_rels/
/customXml/
/docProps/
/[Content_Types].xml

# Root-level generated/stress-test PPTX files
/*.pptx

# Generated example outputs
examples/*.pptx
examples/output/

# Internal QA documents
QA_FINDINGS*.md


# CI test output
/test_ci_output/

# Auto Claude data directory
.auto-claude/

# Claude Code configuration (local AI assistant settings)
.claude/

# Go workspace files (not committed for publishable modules)
go.work
go.work.sum

# Beads issue tracker (internal project management)
.beads/

